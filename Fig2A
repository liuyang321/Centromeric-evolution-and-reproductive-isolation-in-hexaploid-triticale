#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
Plot country-level accession summary for AABB, RR, and AABBRR accessions.

Input file:
    data/allcountry.csv

Required columns:
    country,AABB,RR,AABBRR

Output:
    figures/country_level_accession_summary_top15.png
    figures/country_level_accession_summary_top15.pdf
"""

import pandas as pd
import matplotlib.pyplot as plt
from pathlib import Path


def plot_country_accession_summary(
    input_csv="data/allcountry.csv",
    output_dir="figures",
    top_n=15
):
    # Load data
    df = pd.read_csv(input_csv)

    group_cols = ["AABB", "RR", "AABBRR"]

    # Calculate total number of accessions per country
    df["Total"] = df[group_cols].sum(axis=1)

    # Sort countries by total accession number
    df = df.sort_values("Total", ascending=False).reset_index(drop=True)

    # Keep top N countries and merge the rest as "Others"
    top = df.iloc[:top_n].copy()
    others = df.iloc[top_n:][group_cols].sum()

    others_row = pd.DataFrame([{
        "country": "Others",
        "AABB": others["AABB"],
        "RR": others["RR"],
        "AABBRR": others["AABBRR"],
        "Total": others.sum()
    }])

    plot_df = pd.concat([top, others_row], ignore_index=True)

    # Create output directory
    output_dir = Path(output_dir)
    output_dir.mkdir(parents=True, exist_ok=True)

    # Plot
    fig, ax = plt.subplots(figsize=(9, 7.5))

    left = pd.Series([0] * len(plot_df))

    for col in group_cols:
        ax.barh(
            plot_df["country"],
            plot_df[col],
            left=left,
            label=col
        )
        left = left + plot_df[col]

    # Add total accession number at the end of each bar
    for i, total in enumerate(plot_df["Total"]):
        ax.text(
            total + 0.5,
            i,
            str(int(total)),
            va="center",
            fontsize=9
        )

    ax.set_xlabel("Number of accessions")
    ax.set_ylabel("")
    ax.set_title("Country-level summary of accession origins")
    ax.legend(frameon=False)

    # Largest bar on top
    ax.invert_yaxis()

    # Add space for total labels
    ax.set_xlim(0, plot_df["Total"].max() + 8)

    plt.tight_layout()

    # Save figure
    png_path = output_dir / "country_level_accession_summary_top15.png"
    pdf_path = output_dir / "country_level_accession_summary_top15.pdf"

    plt.savefig(png_path, dpi=300, bbox_inches="tight")
    plt.savefig(pdf_path, bbox_inches="tight")
    plt.close()

    print(f"Saved: {png_path}")
    print(f"Saved: {pdf_path}")


if __name__ == "__main__":
    plot_country_accession_summary(
        input_csv="data/allcountry.csv",
        output_dir="figures",
        top_n=15
    )
